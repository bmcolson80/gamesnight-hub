{
  "name": "gamesnight-hub",
  "version": "1.0.0",
  "description": "GamesNight - shared login and launcher for the game collection",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:local": "AZUL_URL=http://localhost:3000 MAHJONG_URL=http://localhost:3001 PORT=4000 node --watch server.js",
    "test": "AZUL_URL=http://localhost:9999 MAHJONG_URL=http://localhost:9998 DB_PATH=/tmp/gamesnight-test.db node --test --test-timeout=15000 tests/e2e.test.js",
    "migrate-users": "node scripts/import-users.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.12.4",
    "sql.js": "^1.14.1",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
